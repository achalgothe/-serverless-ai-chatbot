# AI API Keys (at least one required)

# Groq (FREE - Recommended) - Get key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# OpenAI (paid) - Get key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# Serverless Stage
STAGE=dev
